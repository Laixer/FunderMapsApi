# Server
PORT=3000

# Database
DATABASE_URL=postgres://postgres@localhost:5432/fundermaps

# Application
APP_ID=app-default

# ZITADEL (required)
ZITADEL_ISSUER=https://your-instance.zitadel.cloud
ZITADEL_CLIENT_ID=

# S3 / DigitalOcean Spaces (optional)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Mailgun (optional)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_API_BASE=https://api.eu.mailgun.net/v3
EMAIL_RECEIVERS=

# PDF service (optional)
PDF_SERVICE_URL=

# Proxy (optional)
PROXY_ENABLED=false
PROXY_HEADER=X-Forwarded-For
